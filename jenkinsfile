pipeline {
agent any
stages {
 stage('clone code') {
  steps {
    git branch: 'master', url: 'https://github.com/RITHICK861/gits/tree/master'
    }
   }
   stage('compile code') {
    steps {
     bat 'javac dem.java'
     }
    }
    stage('run code') {
    steps {
     bat 'java dem.java'
     }
    }
   }
  } 
